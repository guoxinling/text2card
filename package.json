{
  "name": "xiaohongshu-layout-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run styles:build",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "styles:build": "tailwindcss -i ./tailwind.input.css -o ./tailwind.generated.css --minify",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "syntax": "node --check server.js && node --check script.js && node --check export.js",
    "check": "npm run lint && npm run format:check && npm run syntax"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "html-to-image": "^1.11.13"
  }
}
